# Example environment variables for ORYA Flask app
# Copy this file to .env and fill in real values before running.

FLASK_ENV=production
SECRET_KEY=change_this_to_a_random_secret
# Database URL – SQLite (default) or Postgres, MySQL, etc.
DATABASE_URL=sqlite:///app.db

# Mail server configuration (used by Flask‑Mail)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password

# OpenAI API key (if you use OpenAI services)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Any other custom settings used in the project can be added here
